generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  STORE_OWNER
  ADMIN
}

enum BookingStatus {
  PLACED
  ACCEPTED
  READY
  REJECTED
  COMPLETED
  CANCEL_REQUESTED
  CANCELLED
}

model User {
  id           String @id @default(uuid())
  email        String @unique
  passwordHash String
  firstName    String
  role         Role   @default(USER)

  warningsCount Int      @default(0)
  isBlocked     Boolean  @default(false)

  prefBookingNotifications  Boolean @default(true)
  prefPromoAlerts           Boolean @default(true)
  prefNewStoreNotifications Boolean @default(true)

  store              Store?
  carts              Cart[]
  bookings           Booking[]
  storeOwnerRequests StoreOwnerRequest[]
  storeBlocks        StoreBlock[]
}

model Store {
  id         String @id @default(uuid())
  ownerId    String @unique
  name       String
  tagline    String?
  hostel     String
  roomNumber String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  announcementSent Boolean @default(false)

  owner    User      @relation(fields: [ownerId], references: [id])
  items    Item[]
  carts    Cart[]
  bookings Booking[]
  storeBlocks StoreBlock[]
  campaigns   SaleCampaign[]
}

model Item {
  id            String @id @default(uuid())
  storeId       String
  name          String
  price         Float
  imageUrl      String
  stockQuantity Int
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  store        Store         @relation(fields: [storeId], references: [id])
  cartItems    CartItem[]
  bookingItems BookingItem[]
}

model Cart {
  id      String @id @default(uuid())
  userId  String
  storeId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User       @relation(fields: [userId], references: [id])
  store Store      @relation(fields: [storeId], references: [id])
  items CartItem[]

  @@unique([userId, storeId])
}

model CartItem {
  id       String @id @default(uuid())
  cartId   String
  itemId   String
  quantity Int

  cart Cart @relation(fields: [cartId], references: [id])
  item Item @relation(fields: [itemId], references: [id])

  @@unique([cartId, itemId])
}

model Booking {
  id                 String @id @default(uuid())
  orderNumber        String
  userId             String
  storeId            String
  totalAmount        Float
  status             BookingStatus @default(PLACED)
  statusBeforeCancel BookingStatus?
  readyAt            DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user  User          @relation(fields: [userId], references: [id])
  store Store         @relation(fields: [storeId], references: [id])
  items BookingItem[]

  discountApplied   Float?
  appliedCouponCode String?
  campaignId        String?
  campaign          SaleCampaign? @relation(fields: [campaignId], references: [id])
}

model BookingItem {
  id        String @id @default(uuid())
  bookingId String
  itemId    String
  quantity  Int
  unitPrice Float

  booking Booking @relation(fields: [bookingId], references: [id])
  item    Item    @relation(fields: [itemId], references: [id])
}

model StoreOwnerRequest {
  id     String @id @default(uuid())
  userId String
  status String @default("PENDING")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model StoreBlock {
  id        String   @id @default(uuid())
  userId    String
  storeId   String
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([userId, storeId])
}

enum DiscountType {
  PERCENTAGE
  FLAT
}

model SaleCampaign {
  id            String       @id @default(uuid())
  storeId       String
  code          String       @unique
  discountType  DiscountType
  discountValue Float
  startDate     DateTime
  endDate       DateTime
  minOrderValue Float        @default(0)
  globalLimit   Int?
  perUserLimit  Int?
  usedCount     Int          @default(0)
  isActive      Boolean      @default(false)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  store         Store        @relation(fields: [storeId], references: [id])
  bookings      Booking[]
}
